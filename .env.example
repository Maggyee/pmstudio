# Optional demo password for cloud deployments.
# When PMSTUDIO_DEMO_PASSWORD is set, PM Studio requires HTTP Basic Auth.
PMSTUDIO_DEMO_USER=pmstudio
PMSTUDIO_DEMO_PASSWORD=

# Keep off by default. Enable only on a protected cloud host with Codex/Claude Code installed.
PMSTUDIO_ENABLE_CLOUD_AGENTS=0

# Local development-only agent execution switch.
PMSTUDIO_ENABLE_LOCAL_AGENT=0
